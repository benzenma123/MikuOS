pkgname=mikuos-branding
  pkgver=0.2
  pkgrel=2
  pkgdesc="Branding assets for MikuOS"
  arch=('any')
  license=('custom')
  depends=('fastfetch' 'jp2a')
  source=('mikuos-wallpaper.jpg' 'mikuos-logo.png' 'mikuos-logo.jpg' 'config.jsonc')
  sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP')

  package() {
      install -Dm644 "$srcdir/mikuos-wallpaper.jpg" \
          "$pkgdir/usr/share/wallpapers/MikuOS/contents/images/1920x1080.jpg"

      install -Dm644 "$srcdir/mikuos-logo.png" \
          "$pkgdir/usr/share/icons/hicolor/512x512/apps/mikuos.png"

      install -Dm644 "$srcdir/mikuos-logo.jpg" \
          "$pkgdir/usr/share/mikuos/mikuos-logo.jpg"

      install -Dm644 "$srcdir/config.jsonc" \
          "$pkgdir/etc/xdg/fastfetch/config.jsonc"
  }
